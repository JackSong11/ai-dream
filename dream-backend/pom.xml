<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.1.0</version>
        <relativePath/>
    </parent>

    <groupId>com.example.dream</groupId>
    <artifactId>dream-backend</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <name>dream-backend</name>
    <description>ai-dream backend parent</description>
    <packaging>pom</packaging>

    <properties>
        <java.version>21</java.version>
        <dream.version>0.0.1-SNAPSHOT</dream.version>
    </properties>

    <modules>
        <module>dream-common</module>
        <module>dream-dal</module>
        <module>dream-integration</module>
        <module>dream-processor</module>
        <module>dream-service</module>
        <module>dream-app-web</module>
        <module>dream-app-starter</module>
    </modules>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.example.dream</groupId>
                <artifactId>dream-common</artifactId>
                <version>${dream.version}</version>
            </dependency>
            <dependency>
                <groupId>com.example.dream</groupId>
                <artifactId>dream-dal</artifactId>
                <version>${dream.version}</version>
            </dependency>
            <dependency>
                <groupId>com.example.dream</groupId>
                <artifactId>dream-integration</artifactId>
                <version>${dream.version}</version>
            </dependency>
            <dependency>
                <groupId>com.example.dream</groupId>
                <artifactId>dream-processor</artifactId>
                <version>${dream.version}</version>
            </dependency>
            <dependency>
                <groupId>com.example.dream</groupId>
                <artifactId>dream-service</artifactId>
                <version>${dream.version}</version>
            </dependency>
            <dependency>
                <groupId>com.example.dream</groupId>
                <artifactId>dream-app-web</artifactId>
                <version>${dream.version}</version>
            </dependency>
            <dependency>
                <groupId>org.projectlombok</groupId>
                <artifactId>lombok</artifactId>
                <version>1.18.30</version>
                <scope>provided</scope>
            </dependency>
            <!-- 这行代码是版本管理。在 Maven 术语中，通过 <scope>import</scope> 的方式将一个 POM 文件的定义拉取到当前项目的 <dependencyManagement> 中，这个动作在官方定义里就叫做 “Importing a BOM” （导入/引入一个BOM）。-->
            <!-- 当你用 <scope>import</scope> 把 spring-ai-bom 写进 <dependencyManagement> 时，你其实是在项目里引入了一份官方的“标准版本清单”。此时，Maven 没有去下载任何具体的 AI 功能代码。但它成功把 2.0.0 版本的 Spring AI 版本控制规则引入到了你的整个项目生命周期中。-->
            <!-- 为什么必须这样“两步走”？-->
            <!-- Spring AI 旗下有几十个子模块（比如 spring-ai-openai、spring-ai-deepseek、spring-ai-ollama、spring-ai-pgvector 等等）。-->
            <!-- 如果不引入 BOM，你每次想换版本，都要把这几十个子模块的版本号全部手动改一遍，而且极其容易发生版本冲突（比如 OpenAI Starter 用的是 1.0，矢量数据库用的是 2.0，直接崩掉）。-->
            <dependency>
                <groupId>org.springframework.ai</groupId>
                <artifactId>spring-ai-bom</artifactId>
                <version>2.0.0</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

</project>